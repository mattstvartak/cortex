# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo
.next/
next-env.d.ts

# Environment and secrets
.env
.env.local
.env.*.local
.env.bak.*
*.pem
*.key
credentials.json
credentials/

# Client-specific config — never committed, always overrides the .yaml template
# See docs/PRIVACY.md for the rule.
config/*.local.yaml
config/local/
config/local/**

# Per-user runtime state (approvals, heartbeat, personal Engram data dir)
.cortex/

# Default Docker bind-mount target when CORTEX_HOME_HOST is unset
.cortex-data/

# Wizard backups
**/*.bak.*

# Logs
/logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Test artifacts
coverage/
.nyc_output/
test-results/
playwright-report/

# IDE and OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.idea/

# Turborepo / Nx (if added later)
.turbo/
.nx/

# Local-only Claude state
.claude/settings.local.json

# Runtime data
tmp/
.cache/
