# Cortex per-host env — template.
#
# Copy to /etc/cortex/env (mode 0640, owner cortex:cortex) and fill in
# values. Anything left commented out falls back to whatever cortex.yaml
# specifies, or the binary's compiled-in default. See cortex.service for
# the loader directive.
#
# This file is sourced as systemd Environment=, NOT a shell script:
#   - no `export`, no quoting beyond what systemd parses
#   - one KEY=VALUE per line
#   - no inline comments after a value

# --- Memory backend ---
# By default the install script writes a cortex.yaml using embedded
# PGlite (zero external dependency). Override here to point at a real
# Postgres (RDS, Neon, Supabase, internal cluster, etc).
# DATABASE_URL=postgres://USER:PASS@HOST:5432/cortex

# --- LLM provider (optional) ---
# Cortex's pure ingestion + kb_search work without an LLM. Setting this
# unlocks summarization, classification, dossier synthesis.
# OPENROUTER_API_KEY=

# --- Config path override ---
# Defaults to <CORTEX_HOME>/config/cortex.yaml when unset.
# CORTEX_CONFIG_PATH=/opt/cortex/config/cortex.yaml

# --- Telemetry / log level ---
# trace | debug | info | warn | error
# CORTEX_LOG_LEVEL=info
