{
  "name": "cortex-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for @onenomad/cortex and related packages. Open-source adapters, pipelines, providers, SDKs, storage backends, and the reference MCP server.",
  "type": "module",
  "license": "Apache-2.0",
  "author": "OneNomad LLC",
  "homepage": "https://pyre.sh",
  "repository": {
    "type": "git",
    "url": "https://github.com/OneNomad-LLC/cortex.git"
  },
  "bugs": {
    "url": "https://github.com/OneNomad-LLC/cortex/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter @onenomad/cortex run dev",
    "cortex": "pnpm --filter @onenomad/cortex exec node --import=tsx src/index.ts",
    "init": "pnpm --filter @onenomad/cortex exec node --import=tsx src/index.ts init",
    "smoke": "pnpm --filter @onenomad/cortex exec node --import=tsx src/index.ts smoke",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:int": "pnpm -r run test:int",
    "clean": "pnpm -r run clean"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/node": "^22.7.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.12.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.0"
  }
}
