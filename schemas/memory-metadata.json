{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cortex.local/schemas/memory-metadata.json",
  "title": "Cortex Memory Metadata",
  "description": "Metadata envelope attached to every memory ingested into Engram by Cortex. Breaking this contract silently breaks retrieval quality.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "domain",
    "source",
    "source_id",
    "source_url",
    "project",
    "type",
    "people",
    "date",
    "confidence"
  ],
  "properties": {
    "domain": {
      "type": "string",
      "const": "work",
      "description": "Always \"work\" for Cortex-ingested memories."
    },
    "source": {
      "type": "string",
      "enum": [
        "loom",
        "google_meet",
        "confluence",
        "notion",
        "google_drive",
        "jira",
        "linear",
        "bitbucket",
        "github",
        "calendar",
        "slack",
        "teams",
        "email",
        "obsidian"
      ]
    },
    "source_id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable identifier from the source, used as the idempotency key."
    },
    "source_url": {
      "type": "string",
      "format": "uri"
    },
    "project": {
      "oneOf": [
        { "type": "string", "minLength": 1 },
        { "type": "array", "items": { "type": "string", "minLength": 1 } }
      ],
      "description": "Slug(s) from config/projects.yaml."
    },
    "type": {
      "type": "string",
      "enum": [
        "meeting",
        "decision",
        "action_item",
        "doc",
        "code",
        "note",
        "brief",
        "digest",
        "conversation",
        "commit",
        "event",
        "reference"
      ]
    },
    "people": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Person slugs from config/people.yaml. May be empty."
    },
    "date": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the content itself, not ingestion time."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "0-1. Low values flag the memory for review."
    },
    "title": {
      "type": "string",
      "description": "Human-readable title for UI/logs."
    },
    "parent_id": {
      "type": "string",
      "description": "For hierarchical content (Confluence child pages, threaded comments)."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Freeform secondary categorization."
    }
  }
}
