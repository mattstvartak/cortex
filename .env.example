# ==============================================================================
# Cortex environment variables. Copy to `.env` and fill in.
# `.env` is gitignored. Never commit real secrets.
# ==============================================================================

# ------------------------------------------------------------------------------
# Upstream MCP services (localhost during dev; Tailscale hostnames in prod)
# ------------------------------------------------------------------------------
ENGRAM_MCP_URL=http://localhost:3101
PERSONA_MCP_URL=http://localhost:3102

# ------------------------------------------------------------------------------
# LLM providers - enable any combination via config/cortex.yaml
# Every provider is optional. Fill in only the ones you'll use.
# ------------------------------------------------------------------------------

# Ollama (local). Point at Windows host over Tailscale.
OLLAMA_HOST=http://localhost:11434
OLLAMA_FALLBACK_HOST=

# OpenRouter (cloud aggregator - one key for many models)
OPENROUTER_API_KEY=

# Direct BYOK providers (future packages; env vars reserved now)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ------------------------------------------------------------------------------
# Source adapter credentials (enable adapters in config/cortex.yaml)
# ------------------------------------------------------------------------------

# Loom (Phase 4)
LOOM_API_KEY=

# Atlassian - Confluence + Jira + Bitbucket (one API token covers all)
ATLASSIAN_EMAIL=
ATLASSIAN_API_TOKEN=
ATLASSIAN_WORKSPACE=

# Notion integration token (https://www.notion.so/profile/integrations)
NOTION_API_KEY=

# Linear personal API key (https://linear.app/settings/api)
LINEAR_API_KEY=

# Google Calendar (Phase 6) - OAuth client, token stored separately
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=

# Obsidian (Phase 9) - path to vault on the machine running the adapter
OBSIDIAN_VAULT_PATH=

# ------------------------------------------------------------------------------
# Runtime
# ------------------------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info
CORTEX_CONFIG_PATH=./config/cortex.yaml
CORTEX_MCP_PORT=3100
