{
  "name": "@onenomad/cortex-cache-sqlite",
  "version": "0.0.0",
  "private": true,
  "description": "SQLite-backed dashboard widget cache. ADR-019 Phase 1 — single-table cache_widgets keyed by (widget, workspace, cache_key).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=22.16"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "rimraf": "^6.0.1",
    "eslint": "^9.12.0"
  }
}
