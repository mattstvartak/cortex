{
  "name": "@onenomad/cortex-memory-remote",
  "version": "0.0.0",
  "private": true,
  "description": "HTTP-backed EngramClient for federated Cortex memory (ADR-016).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@onenomad/cortex-core": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.0",
    "eslint": "^9.12.0"
  }
}
