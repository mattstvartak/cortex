{
  "name": "@cortex/github-auth",
  "version": "0.0.0",
  "private": true,
  "description": "GitHub device-flow auth + token storage for Cortex.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "rimraf": "^6.0.1",
    "vitest": "^2.1.0",
    "eslint": "^9.12.0"
  }
}
