{
  "name": "@onenomad/cortex",
  "version": "0.0.0",
  "description": "Cortex MCP server: unified work-knowledge layer on Engram and Persona.",
  "keywords": [
    "mcp",
    "claude",
    "cortex",
    "knowledge",
    "memory"
  ],
  "author": "OneNomad",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cortex": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "cross-env NODE_ENV=development node --import=tsx --watch src/index.ts start",
    "start": "node dist/index.js start",
    "smoke:llm": "node --import=tsx src/index.ts smoke",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:int": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@cortex/core": "workspace:*",
    "@cortex/adapter-sdk": "workspace:*",
    "@cortex/github-auth": "workspace:*",
    "@cortex/google-auth": "workspace:*",
    "@cortex/llm-core": "workspace:*",
    "@cortex/llm-sdk": "workspace:*",
    "@cortex/memory-pgvector": "workspace:*",
    "@cortex/pipeline-core": "workspace:*",
    "@cortex/pipeline-code": "workspace:*",
    "@cortex/pipeline-conversation": "workspace:*",
    "@cortex/pipeline-doc": "workspace:*",
    "@cortex/pipeline-meeting": "workspace:*",
    "@cortex/pipeline-research": "workspace:*",
    "@cortex/provider-ollama": "workspace:*",
    "@cortex/provider-openrouter": "workspace:*",
    "@cortex/adapter-bitbucket": "workspace:*",
    "@cortex/adapter-confluence": "workspace:*",
    "@cortex/adapter-github": "workspace:*",
    "@cortex/adapter-gmail": "workspace:*",
    "@cortex/adapter-google-calendar": "workspace:*",
    "@cortex/adapter-google-drive": "workspace:*",
    "@cortex/adapter-jira": "workspace:*",
    "@cortex/adapter-linear": "workspace:*",
    "@cortex/adapter-loom": "workspace:*",
    "@cortex/adapter-notion": "workspace:*",
    "@cortex/adapter-obsidian": "workspace:*",
    "@cortex/adapter-slack": "workspace:*",
    "@onenomad/engram-memory": "^1.0.0-beta.8",
    "@onenomad/persona-mcp": "^1.0.0-beta.6",
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "yaml": "^2.6.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "typescript": "^5.6.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "vitest": "^2.1.0",
    "eslint": "^9.12.0"
  }
}
