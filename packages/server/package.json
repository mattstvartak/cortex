{
  "name": "@onenomad/cortex",
  "version": "0.0.0",
  "description": "Cortex MCP server: unified work-knowledge layer on Engram and Persona.",
  "keywords": [
    "mcp",
    "claude",
    "cortex",
    "knowledge",
    "memory"
  ],
  "author": "OneNomad",
  "license": "UNLICENSED",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cortex": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rimraf dist",
    "dev": "cross-env NODE_ENV=development node --import=tsx --watch src/index.ts start",
    "start": "node dist/index.js start",
    "smoke:llm": "node --import=tsx src/index.ts smoke",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "test:int": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@onenomad/cortex-adapter-bitbucket": "^0.1.0",
    "@onenomad/cortex-adapter-confluence": "^0.1.0",
    "@onenomad/cortex-adapter-github": "^0.1.0",
    "@onenomad/cortex-adapter-jira": "^0.1.0",
    "@onenomad/cortex-adapter-linear": "^0.1.0",
    "@onenomad/cortex-adapter-loom": "^0.1.0",
    "@onenomad/cortex-adapter-notion": "^0.1.0",
    "@onenomad/cortex-adapter-obsidian": "^0.1.0",
    "@onenomad/cortex-adapter-sdk": "^0.1.0",
    "@onenomad/cortex-adapter-slack": "^0.1.0",
    "@onenomad/cortex-cache-sqlite": "^0.1.0",
    "@onenomad/cortex-core": "^0.1.0",
    "@onenomad/cortex-github-auth": "^0.1.0",
    "@onenomad/cortex-llm-core": "^0.1.0",
    "@onenomad/cortex-memory-pgvector": "^0.1.0",
    "@onenomad/cortex-pipeline-code": "^0.1.0",
    "@onenomad/cortex-pipeline-conversation": "^0.1.0",
    "@onenomad/cortex-pipeline-core": "^0.1.0",
    "@onenomad/cortex-pipeline-doc": "^0.1.0",
    "@onenomad/cortex-pipeline-meeting": "^0.1.0",
    "pdf-parse": "^2.4.5",
    "ws": "^8.18.0",
    "yaml": "^2.6.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  },
  "optionalDependencies": {
    "@onenomad/cortex-llm-sdk": "^0.1.0",
    "@onenomad/cortex-provider-ollama": "^0.1.0",
    "@onenomad/cortex-provider-openrouter": "^0.1.0"
  },
  "devDependencies": {
    "@types/ws": "^8.5.13",
    "cross-env": "^7.0.3",
    "eslint": "^9.12.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
