{
  "name": "@onenomad/cortex-pipeline-notification",
  "version": "0.0.0",
  "private": true,
  "description": "Active push pipeline — formats and dispatches morning brief / pre-meeting / EOD notifications via a pluggable transport (Slack today, more later). Prong B of the cortex active-accountability surface.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node -e \"const{cpSync,existsSync,mkdirSync}=require('fs');mkdirSync('dist/prompts',{recursive:true});cpSync('src/prompts','dist/prompts',{recursive:true});\"",
    "clean": "rimraf dist",
    "typecheck": "tsc --build",
    "lint": "eslint src",
    "test": "node --test tests/*.test.mjs"
  },
  "engines": {
    "node": ">=22.16"
  },
  "dependencies": {
    "@onenomad/cortex-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0",
    "rimraf": "^6.0.1",
    "eslint": "^9.12.0"
  }
}
